@page "/"
@using Microsoft.SemanticKernel
@using Microsoft.SemanticKernel.ChatCompletion
@rendermode InteractiveServer
@inject Kernel Kernel
@inject IChatCompletionService ChatService

<PageTitle>Home</PageTitle>

<h1>Hello Pal!</h1>

<h3>Welcome to your AI Buddy Web Chat.</h3>

<div class="mb-3">
    <label for="personaSelect" class="form-label"><strong>With which friend do you want to chat?</strong></label>
    <select id="personaSelect" class="form-select" @bind="selectedPersona">
        @foreach (var persona in personas.Keys)
        {
            <option value="@persona">@persona</option>
        }
    </select>
</div>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">Question</h5>
        <textarea class="form-control" @bind="@message" @ref="messageInput" @onkeydown="HandleKeyDown"></textarea>
        <button class="btn btn-primary mt-2" @onclick="Submit">Ask</button>
        <button class="btn btn-secondary mt-2 ms-2" @onclick="ClearMessage">Clear</button>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h5 class="card-title">Response</h5>
        <div>@(GetResponseMarkup())</div>
    </div>
</div>

@code {
    private string message;
    private string response;
    ChatHistory history = new();
    private ElementReference messageInput;
    private bool isInteractiveRendered;

    private string _selectedPersona = "Scriptorian";
    private string selectedPersona
    {
        get => _selectedPersona;
        set
        {
            if (_selectedPersona != value)
            {
                _selectedPersona = value;
                SetPersona(_selectedPersona);
                response = string.Empty;
                message = string.Empty;
                InvokeAsync(async () =>
                {
                    await InvokeAsync(StateHasChanged);
                    if (isInteractiveRendered)
                    {
                        await messageInput.FocusAsync();
                    }
                });
            }
        }
    }
